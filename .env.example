# Configuração do Firebase (Web App) — projeto criado em projetobrotadigital@gmail.com
# Copie este arquivo para ".env" e preencha com os valores do seu projeto Firebase.
# No Netlify, cadastre as mesmas variáveis em Site settings > Environment variables.
# Tudo que começa com VITE_ vai para o bundle (é público, como todo config Firebase Web).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
